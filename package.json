{
  "name": "discord-attestation",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --parallel run build",
    "dev": "pnpm -r --parallel run dev",
    "preinstall": "npx only-allow@1.2.2 pnpm",
    "lint": "eslint updateReadme.ts && pnpm -r --parallel run lint && prettier --check 'updateReadme.ts' '*.json' && pnpm -r --parallel run prettier",
    "lint:fix": "eslint --fix updateReadme.ts && pnpm -r --parallel run lint:fix && prettier --write 'updateReadme.ts' '*.json' && pnpm -r --parallel run prettier:fix",
    "prepare": "husky",
    "test": "pnpm -r --parallel run test",
    "typecheck": "tsc --noEmit && pnpm -r --parallel run typecheck",
    "update-readme": "tsx updateReadme.ts"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "husky": "^9.1.7",
    "prettier": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": "22.21.1",
    "pnpm": "10.26.2"
  }
}
