{
  "name": "@discord-attestation/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "deploy": "node --env-file=.env ./node_modules/hardhat/dist/src/cli.js run scripts/deployDiscord.ts --network",
    "lint": "eslint . && pnpm run solhint",
    "lint:fix": "eslint --fix .",
    "prettier": "prettier --check '**/*.sol' '**/*.ts' '**/*.json'",
    "prettier:fix": "prettier --write '**/*.sol' '**/*.ts' '**/*.json'",
    "solhint": "solhint **/*.sol -c .solhint.json",
    "test": "hardhat test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.0.2",
    "@openzeppelin/contracts-upgradeable": "5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@nomicfoundation/hardhat-verify": "catalog:",
    "@nomicfoundation/hardhat-viem": "catalog:",
    "@types/node": "catalog:",
    "@verax-attestation-registry/verax-contracts": "^10.0.0",
    "@verax-attestation-registry/verax-sdk": "catalog:",
    "eslint": "catalog:",
    "hardhat": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-solidity": "^2.3.1",
    "solhint": "^6.2.1",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "viem": "catalog:"
  }
}
