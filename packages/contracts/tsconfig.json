{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.contracts.tsbuildinfo",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "verbatimModuleSyntax": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": ["scripts/**/*.ts", "hardhat.config.ts"],
  "exclude": ["node_modules", "typechain-types", "artifacts", "cache"]
}
