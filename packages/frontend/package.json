{
  "name": "@discord-attestation/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prettier": "prettier --check 'src/**/*.ts' 'src/**/*.tsx' 'src/**/*.css' 'e2e/**/*.ts' '*.ts' '*.json'",
    "prettier:fix": "prettier --write 'src/**/*.ts' 'src/**/*.tsx' 'src/**/*.css' 'e2e/**/*.ts' '*.ts' '*.json'",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19",
    "@tanstack/react-query": "catalog:",
    "@verax-attestation-registry/verax-sdk": "catalog:",
    "@wagmi/core": "catalog:",
    "axios": "catalog:",
    "date-fns": "^4.1.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-icons": "^5.6.0",
    "viem": "catalog:",
    "wagmi": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "catalog:",
    "jsdom": "^29.1.1",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.5"
  }
}
